# 仅「AI 卡通化」功能需要。复制本文件为 .env 并填入你自己的 key。

# 选后端：openrouter（默认）或 volcano（火山方舟）
REDRAW_BACKEND=openrouter

# 后端 A：OpenRouter（默认，模型 bytedance-seed/seedream-4.5）
OPENROUTER_API_KEY=

# 后端 B：火山方舟 Ark（设 REDRAW_BACKEND=volcano 时用）
# ARK_API_KEY=
# 可选：覆盖模型（如切到 seedream 5.0 lite，填控制台给的完整模型ID）
# REDRAW_MODEL=doubao-seedream-5-0-lite-xxxxxxxx
